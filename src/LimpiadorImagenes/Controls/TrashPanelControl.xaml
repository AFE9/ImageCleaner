<UserControl x:Class="LimpiadorImagenes.Controls.TrashPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LimpiadorImagenes.Converters">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource BgPanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}" Padding="10,8">
            <DockPanel>
                <TextBlock Text="PAPELERA" Style="{StaticResource MetaLabelStyle}"
                           DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0"/>
                <Border Background="{StaticResource DangerBrush}" CornerRadius="8"
                        HorizontalAlignment="Right" Padding="6,1">
                    <TextBlock Text="{Binding Items.Count}"
                               Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- Empty state -->
        <TextBlock Grid.Row="1"
                   Text="Papelera vacía"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="11" FontStyle="Italic"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Scrollable thumbnail list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="6,6,4,6">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,6" CornerRadius="4"
                                Background="{StaticResource BgCardBrush}"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="150"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail -->
                                <Image Grid.Row="0"
                                       Source="{Binding Thumbnail}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"
                                       ClipToBounds="True"/>

                                <!-- Restore button overlay (top-right) -->
                                <Button Grid.Row="0"
                                        Content="↩"
                                        Width="28" Height="28"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,4,4,0"
                                        Background="#CC111111"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="14" FontWeight="Bold"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Recuperar archivo"
                                        Command="{Binding DataContext.RestoreFromTrashCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding File}"/>

                                <!-- Info bar -->
                                <Border Grid.Row="1" Background="{StaticResource BgPanelBrush}" Padding="6,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding File.FileName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="9" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding File.FormattedSize}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="9"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
