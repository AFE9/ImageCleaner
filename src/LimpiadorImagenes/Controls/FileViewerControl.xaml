<UserControl x:Class="LimpiadorImagenes.Controls.FileViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LimpiadorImagenes.Converters"
             Background="{StaticResource BgDeepBrush}"
             ClipToBounds="True">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisible"/>
        <converters:NullToVisibilityConverter x:Key="NullToCollapsed" Invert="True"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisible"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToCollapsedInv" Invert="True"/>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!-- Loading spinner -->
        <TextBlock Text="Cargando..."
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="14"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisible}}"/>

        <!-- Empty state -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding CurrentPreview, Converter={StaticResource NullToCollapsed}}">
            <TextBlock Text="📂"  FontSize="48" HorizontalAlignment="Center"
                       Foreground="{StaticResource TextMutedBrush}"/>
            <TextBlock Text="Selecciona una carpeta para comenzar"
                       Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                       Margin="0,12,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Static image layer -->
        <Image x:Name="ImageView"
               Source="{Binding CurrentPreview.StaticImage}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               Visibility="{Binding CurrentPreview.IsImage, Converter={StaticResource BoolToVisible}}"
               MouseDown="ImageView_MouseDown"
               MouseUp="ImageView_MouseUp"
               MouseMove="ImageView_MouseMove"/>

        <!-- Video layer -->
        <MediaElement x:Name="VideoView"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      IsMuted="True"
                      Stretch="Uniform"
                      MediaEnded="VideoView_MediaEnded"
                      Visibility="{Binding CurrentPreview.IsVideo, Converter={StaticResource BoolToVisible}}"/>

        <!-- Text / Document layer -->
        <ScrollViewer x:Name="TextScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24"
                      Visibility="{Binding CurrentPreview.IsText, Converter={StaticResource BoolToVisible}}">
            <TextBlock Text="{Binding CurrentPreview.TextContent}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Consolas"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="18"/>
        </ScrollViewer>

        <!-- Magnifier overlay (topmost) -->
        <Canvas x:Name="MagnifierCanvas"
                IsHitTestVisible="False"
                Visibility="{Binding IsMagnifierActive, Converter={StaticResource BoolToVisible}}">
            <Border x:Name="MagnifierBorder"
                    Width="220" Height="220"
                    CornerRadius="110"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="2"
                    Background="Black"
                    ClipToBounds="True">
                <Image x:Name="MagnifierImage" Stretch="None"/>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
