<UserControl x:Class="LimpiadorImagenes.Controls.DuplicateGroupControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LimpiadorImagenes.Converters"
             Background="{StaticResource BgDeepBrush}">

    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" FontWeight="SemiBold">
                        <Run Text="Grupo "/>
                        <Run Text="{Binding GroupIndex, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalGroups, Mode=OneWay}"/>
                        <Run Text=" — "/>
                        <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                        <Run Text=" imágenes similares"/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,2,0,0">
                        <Run FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}">←</Run>
                        <Run>  Borrar marcadas y siguiente  ·  </Run>
                        <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">→</Run>
                        <Run>  Saltar grupo  ·  Click en foto para toggle</Run>
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Empty state -->
        <TextBlock Grid.Row="1"
                   Text="Sin más grupos de duplicados"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="13" FontStyle="Italic"
                   HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Items.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Scrollable photo grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="230" Margin="8"
                                CornerRadius="6"
                                Background="{StaticResource BgCardBrush}"
                                Cursor="Hand"
                                MouseLeftButtonDown="Card_Click"
                                ClipToBounds="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMarkedForDeletion}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail -->
                                <Image Grid.Row="0"
                                       Source="{Binding Thumbnail}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"
                                       ClipToBounds="True"/>

                                <!-- Small badge in top-right corner — does NOT cover the photo -->
                                <Border Grid.Row="0"
                                        Width="30" Height="30" CornerRadius="15"
                                        Background="{StaticResource DangerBrush}"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,6,6,0"
                                        Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="✓" Foreground="White"
                                               FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- "CONSERVAR" label for the keeper (not marked) -->
                                <Border Grid.Row="0"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,6,6,0"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="3" Padding="5,2"
                                        Visibility="{Binding IsMarkedForDeletion, Converter={StaticResource BoolToVisInv}}">
                                    <TextBlock Text="CONSERVAR" Foreground="White"
                                               FontSize="8" FontWeight="Bold"/>
                                </Border>

                                <!-- File info bar -->
                                <Border Grid.Row="1" Background="{StaticResource BgPanelBrush}" Padding="8,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FormattedSize}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="9"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
