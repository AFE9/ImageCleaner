<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <Color x:Key="BgDeepColor">#FF121212</Color>
    <Color x:Key="BgSurfaceColor">#FF1E1E1E</Color>
    <Color x:Key="BgPanelColor">#FF252525</Color>
    <Color x:Key="BgCardColor">#FF2D2D2D</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#FF4FC3F7</Color>
    <Color x:Key="AccentDimColor">#FF1E88E5</Color>
    <Color x:Key="DangerColor">#FFEF5350</Color>
    <Color x:Key="SuccessColor">#FF66BB6A</Color>
    <Color x:Key="WarningColor">#FFFFA726</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#FFEEEEEE</Color>
    <Color x:Key="TextSecondaryColor">#FF9E9E9E</Color>
    <Color x:Key="TextMutedColor">#FF616161</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDeepBrush"      Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush"   Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgPanelBrush"     Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDimBrush"   Color="{StaticResource AccentDimColor}"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"     Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"   Color="{StaticResource TextMutedColor}"/>

</ResourceDictionary>
