<Window x:Class="LimpiadorImagenes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LimpiadorImagenes.Controls"
        xmlns:converters="clr-namespace:LimpiadorImagenes.Converters"
        xmlns:behaviors="clr-namespace:LimpiadorImagenes.Behaviors"
        behaviors:KeyboardNavigationBehavior.ViewModel="{Binding}"
        Title="Limpiador de Imágenes"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BgDeepBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:ProgressBarWidthConverter x:Key="PBWidthConv"/>
        <converters:EnumToBoolConverter x:Key="ModeConverter"/>
    </Window.Resources>

    <!-- Outer grid: layer 0 = main layout, layer 1 = toast overlay -->
    <Grid>

        <DockPanel>
            <!-- ═══ TOOLBAR ═══════════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BgSurfaceBrush}"
                    Padding="12,8">
                <DockPanel>
                    <!-- Left: folder + subdirs -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <Button Content="📂  Abrir Carpeta"
                                Command="{Binding SelectFolderCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Margin="0,0,8,0"/>
                        <CheckBox Content="Incluir subcarpetas"
                                  IsChecked="{Binding IncludeSubdirectories}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding ScanStatusText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                        <ProgressBar Width="120" Height="6" Margin="12,0,0,0"
                                     Value="{Binding ScanProgress}"
                                     Minimum="0" Maximum="100"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource BgCardBrush}"
                                     Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Right: mode buttons -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="MODO:" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ToggleButton Content="Tamaño"       Style="{StaticResource ModeButtonStyle}" Margin="2,0"
                                      IsChecked="{Binding CurrentMode, Converter={StaticResource ModeConverter}, ConverterParameter=Size}"
                                      Command="{Binding SwitchModeCommand}" CommandParameter="Size"/>
                        <ToggleButton Content="Antigüedad"   Style="{StaticResource ModeButtonStyle}" Margin="2,0"
                                      IsChecked="{Binding CurrentMode, Converter={StaticResource ModeConverter}, ConverterParameter=Age}"
                                      Command="{Binding SwitchModeCommand}" CommandParameter="Age"/>
                        <ToggleButton Content="Borrosos ✦"  Style="{StaticResource ModeButtonStyle}" Margin="2,0"
                                      IsChecked="{Binding CurrentMode, Converter={StaticResource ModeConverter}, ConverterParameter=Blur}"
                                      Command="{Binding SwitchModeCommand}" CommandParameter="Blur"/>
                        <ToggleButton Content="Capturas"     Style="{StaticResource ModeButtonStyle}" Margin="2,0"
                                      IsChecked="{Binding CurrentMode, Converter={StaticResource ModeConverter}, ConverterParameter=Screenshot}"
                                      Command="{Binding SwitchModeCommand}" CommandParameter="Screenshot"/>
                        <ToggleButton Content="Duplicados ✦" Style="{StaticResource ModeButtonStyle}" Margin="2,0"
                                      IsChecked="{Binding CurrentMode, Converter={StaticResource ModeConverter}, ConverterParameter=Duplicates}"
                                      Command="{Binding SwitchModeCommand}" CommandParameter="Duplicates"/>
                    </StackPanel>
                    <Rectangle/>
                </DockPanel>
            </Border>

            <!-- ═══ DIRECTORY WEIGHT BAR ════════════════════════════════════ -->
            <Border DockPanel.Dock="Top" Height="20"
                    Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Rectangle Fill="{StaticResource BgCardBrush}"/>
                    <!-- Dynamic fill handled in code-behind via SizeChanged binding -->
                    <Rectangle x:Name="DirectoryWeightFill"
                               Fill="{StaticResource AccentDimBrush}"
                               HorizontalAlignment="Left" Width="0"/>
                    <DockPanel Margin="8,0">
                        <TextBlock Text="Carpeta: " Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalDirectoryBytes, Converter={StaticResource FileSizeConv}}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalFiles, StringFormat=' — {0} archivos'}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" VerticalAlignment="Center"/>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- ═══ BOTTOM BAR ════════════════════════════════════════════ -->
            <Border DockPanel.Dock="Bottom" Height="44"
                    Background="{StaticResource BgSurfaceBrush}"
                    Padding="12,0">
                <DockPanel VerticalAlignment="Center">
                    <!-- Savings bar (left) -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="Ahorro: " Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" VerticalAlignment="Center"/>
                        <Border Width="200" Height="8" CornerRadius="4"
                                Background="{StaticResource BgCardBrush}" Margin="0,0,8,0">
                            <Rectangle x:Name="SavingsFill"
                                       Fill="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Left" Width="0"
                                       RadiusX="4" RadiusY="4"/>
                        </Border>
                        <TextBlock Text="{Binding Trash.TotalBytes, Converter={StaticResource FileSizeConv}}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Trash.Count, StringFormat=' ({0} arch.)'}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Action buttons (right) -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <ProgressBar Width="100" Height="6" Margin="0,0,8,0"
                                     Value="{Binding CleanupProgress}" Minimum="0" Maximum="100"
                                     Foreground="{StaticResource DangerBrush}"
                                     Background="{StaticResource BgCardBrush}"
                                     Visibility="{Binding IsCleaningUp, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="↩  Deshacer"
                                Command="{Binding UndoLastMarkCommand}"
                                Style="{StaticResource BaseButtonStyle}"
                                Margin="0,0,8,0"/>
                        <Button Content="✔  Ejecutar Limpieza"
                                Command="{Binding ExecuteCleanupCommand}"
                                Style="{StaticResource DangerButtonStyle}"/>
                    </StackPanel>

                    <!-- Navigation counter (center) -->
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding CurrentIndex, StringFormat={}{0}}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalFiles}"/>
                    </TextBlock>
                </DockPanel>
            </Border>

            <!-- ═══ PROXIMITY BAR ════════════════════════════════════════════ -->
            <controls:ProximityBarControl DockPanel.Dock="Bottom"
                                          DataContext="{Binding ProximityBar}"/>

            <!-- ═══ MAIN CONTENT: Metadata + Viewer ═════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="200" MinWidth="120" MaxWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- Metadata Panel -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgPanelBrush}"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding Metadata}">
                            <TextBlock Text="ARCHIVO" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Text="{Binding FileName}" Style="{StaticResource MetaValueStyle}"
                                       FontWeight="SemiBold" TextWrapping="Wrap"/>

                            <TextBlock Text="TIPO" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Text="{Binding Extension}" Style="{StaticResource MetaValueStyle}"/>

                            <TextBlock Text="TAMAÑO" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Text="{Binding FormattedSize}" Style="{StaticResource MetaValueStyle}"/>

                            <TextBlock Text="DIMENSIONES" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Text="{Binding Dimensions}" Style="{StaticResource MetaValueStyle}"/>

                            <TextBlock Text="CREACIÓN" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Text="{Binding Created}" Style="{StaticResource MetaValueStyle}"/>

                            <TextBlock Text="MODIFICACIÓN" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Text="{Binding Modified}" Style="{StaticResource MetaValueStyle}"/>

                            <!-- Blur score -->
                            <TextBlock Text="NITIDEZ (BLUR)" Style="{StaticResource MetaLabelStyle}"
                                       Visibility="{Binding HasBlurScore, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Style="{StaticResource MetaValueStyle}"
                                       Visibility="{Binding HasBlurScore, Converter={StaticResource BoolToVis}}">
                                <Run Text="{Binding BlurScore, StringFormat=F0}"/>
                                <Run Text=" (↓ = más borroso)" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>

                            <!-- Keyboard hints -->
                            <Separator Margin="0,16,0,8" Background="{StaticResource BgCardBrush}"/>
                            <TextBlock Text="TECLADO" Style="{StaticResource MetaLabelStyle}"/>
                            <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="10" LineHeight="18">
                                <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">→ / Espacio</Run><Run>  Conservar&#x0A;</Run>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}">← / Retroceso</Run><Run>  Eliminar&#x0A;</Run>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}">U</Run><Run>  Deshacer&#x0A;</Run>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">Z (mantener)</Run><Run>  Lupa</Run>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BgCardBrush}"
                              ShowsPreview="False"/>

                <!-- Col 2: File Viewer or Duplicate Group Review (mutually exclusive) -->
                <Grid Grid.Column="2">
                    <controls:FileViewerControl x:Name="MainViewer"
                        DataContext="{Binding Viewer}"
                        Visibility="{Binding DuplicateGroup.IsActive,
                                     Converter={StaticResource BoolToVisInv}}"/>
                    <controls:DuplicateGroupControl
                        DataContext="{Binding DuplicateGroup}"
                        Visibility="{Binding DuplicateGroup.IsActive,
                                     Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- Splitter -->
                <GridSplitter Grid.Column="3"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BgCardBrush}"
                              ShowsPreview="False"/>

                <!-- Trash Panel -->
                <controls:TrashPanelControl Grid.Column="4"
                                            DataContext="{Binding TrashPanel}"/>
            </Grid>
        </DockPanel>

        <!-- ═══ TOAST OVERLAY (floats on top of everything) ═══════════════ -->
        <Border x:Name="ToastBorder"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,60"
                Background="#DD1E1E1E"
                CornerRadius="6"
                Padding="16,10"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.5" ShadowDepth="2"/>
            </Border.Effect>
            <TextBlock x:Name="ToastText"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13"
                       FontFamily="Segoe UI"/>
        </Border>

    </Grid>
</Window>
