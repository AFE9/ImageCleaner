<Window x:Class="LimpiadorImagenes.Views.GridReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:LimpiadorImagenes.Converters"
        Title="{Binding Title}"
        Width="900" Height="700"
        MinWidth="600" MinHeight="400"
        Background="{StaticResource BgDeepBrush}"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisInv" Invert="True"/>
        <converters:FileSizeConverter x:Key="FileSizeConv"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgSurfaceBrush}" Padding="16,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                        <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                        <Run Text=" archivos encontrados — "/>
                        <Run Text="{Binding SelectedCount}" FontWeight="SemiBold"
                             Foreground="{StaticResource AccentBrush}"/>
                        <Run Text=" seleccionados"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Seleccionar todo"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource BaseButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Deseleccionar todo"
                            Command="{Binding DeselectAllCommand}"
                            Style="{StaticResource BaseButtonStyle}" Margin="0,0,8,0"/>
                    <!-- Modo normal: marcar para eliminar -->
                    <Button Content="✔  Marcar seleccionados para eliminar"
                            Command="{Binding MarkSelectedForDeletionCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Visibility="{Binding IsTrashView, Converter={StaticResource BoolToVisInv}}"/>
                    <!-- Modo papelera: recuperar seleccionados -->
                    <Button Content="↩  Recuperar seleccionados"
                            Command="{Binding RecoverSelectedCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            Visibility="{Binding IsTrashView, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <Rectangle/>
            </DockPanel>
        </Border>

        <!-- Loading indicator -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Cargando miniaturas..."
                   Foreground="{StaticResource TextMutedBrush}"
                   HorizontalAlignment="Center" Margin="0,12"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Thumbnail grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="220" Margin="6"
                                CornerRadius="4"
                                Background="{StaticResource BgCardBrush}"
                                Cursor="Hand"
                                MouseLeftButtonDown="GridItem_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail -->
                                <Image Grid.Row="0"
                                       Source="{Binding Thumbnail}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="LowQuality"
                                       ClipToBounds="True"/>

                                <!-- Selection overlay -->
                                <Border Grid.Row="0"
                                        Background="#880000FF"
                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="✓" FontSize="32" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- File info -->
                                <Border Grid.Row="1" Background="{StaticResource BgPanelBrush}" Padding="8,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FormattedSize}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="9"/>
                                        <TextBlock Text="{Binding BlurInfo}"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   FontSize="9"
                                                   Visibility="{Binding BlurInfo, Converter={StaticResource NullToVis}}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
